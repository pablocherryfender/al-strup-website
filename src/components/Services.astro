---

<section id="uslugi" class="py-20 px-4">
  <div class="max-w-6xl mx-auto">
    <!-- Heading -->
    <div class="text-center mb-14">
      <h2 class="text-3xl md:text-4xl font-bold text-brand-text mb-4">
        Nasze usługi
      </h2>
      <p class="text-brand-text/60 text-lg max-w-xl mx-auto">
        Kompleksowe instalacje i serwis urządzeń grzewczych, chłodniczych
        i sanitarnych na terenie Trójmiasta.
      </p>
    </div>

    <!-- Cards grid -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div
          class={`bg-white rounded-xl p-6 shadow-sm border border-gray-100 hover:-translate-y-1 hover:shadow-md transition-all duration-200${index === 6 ? " sm:col-start-1 lg:col-start-2" : ""}`}
        >
          <div class="w-12 h-12 text-brand-primary mb-4" set:html={service.icon} />
          <h3 class="text-lg font-semibold text-brand-text mb-2">{service.title}</h3>
          <p class="text-brand-text/60 text-sm leading-relaxed">{service.description}</p>
        </div>
      ))}
    </div>

    <!-- Bottom CTA -->
    <div class="text-center mt-12">
      <a
        href="#kontakt"
        class="inline-flex items-center justify-center bg-brand-primary text-white font-semibold px-8 py-4 rounded-lg hover:bg-brand-primary-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-brand-primary"
      >
        Bezpłatna wycena
      </a>
    </div>
  </div>
</section>
