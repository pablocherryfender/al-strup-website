---
// TODO: replace TBD values with real contact details before launch
const year = new Date().getFullYear();
---

<footer class="bg-brand-text text-white mt-16">
  <div class="max-w-6xl mx-auto px-4 py-10 grid grid-cols-1 md:grid-cols-3 gap-8">
    <!-- Brand -->
    <div>
      <a href="/" class="text-xl font-bold tracking-wide hover:opacity-90 transition-opacity">Allross</a>
      <p class="text-white/70 text-sm mt-2">Instalacje i serwis — Trójmiasto</p>
    </div>

    <!-- Contact -->
    <div>
      <p class="text-sm font-semibold text-white/90 mb-2 uppercase tracking-wider">Kontakt</p>
      <ul class="space-y-1 text-sm text-white/70">
        <li>
          <a href="tel:TBD" class="hover:text-white transition-colors">Tel: TBD</a>
        </li>
        <li>
          <a href="mailto:TBD" class="hover:text-white transition-colors">Email: TBD</a>
        </li>
        <li>NIP: TBD</li>
      </ul>
    </div>

    <!-- Area -->
    <div>
      <p class="text-sm font-semibold text-white/90 mb-2 uppercase tracking-wider">Obszar działania</p>
      <p class="text-sm text-white/70">Gdańsk · Gdynia · Sopot<br />i okolice Trójmiasta</p>
    </div>
  </div>

  <div class="border-t border-white/10 py-4 text-center text-xs text-white/70">
    © {year} Allross · Wszelkie prawa zastrzeżone ·
    <a href="/polityka-prywatnosci" class="hover:text-white transition-colors underline">Polityka prywatności</a>
  </div>
</footer>
