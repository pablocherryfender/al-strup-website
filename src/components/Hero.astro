---
// TODO: replace TBD with real phone number before launch
const phoneNumber = "TBD";
---

<section
  class="relative min-h-[90vh] flex items-center bg-gradient-to-br from-brand-primary to-brand-primary-dark"
>
  <div class="max-w-6xl mx-auto px-4 py-24 md:py-32">
    <div class="max-w-2xl">
      <!-- Label -->
      <p class="text-white/70 text-sm font-medium uppercase tracking-widest mb-4">
        Trójmiasto — Gdańsk · Gdynia · Sopot
      </p>

      <!-- Headline -->
      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white leading-tight mb-6">
        Ciepło, chłód i woda<br class="hidden sm:block" />
        w Twoim domu
      </h1>

      <!-- Subheadline -->
      <p class="text-lg md:text-xl text-white/80 mb-10 leading-relaxed">
        Profesjonalny montaż pomp ciepła, klimatyzacji i ogrzewania podłogowego.
        Działamy w Gdańsku, Gdyni i Sopocie oraz okolicznych miejscowościach.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href="#kontakt"
          class="inline-flex items-center justify-center bg-white text-brand-primary font-semibold px-8 py-4 rounded-lg hover:bg-white/90 transition-colors text-base"
        >
          Bezpłatna wycena
        </a>
        <a
          href={`tel:${phoneNumber}`}
          class="inline-flex items-center justify-center border-2 border-white text-white font-semibold px-8 py-4 rounded-lg hover:bg-white/10 transition-colors text-base"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5 mr-2" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z" />
          </svg>
          Zadzwoń
        </a>
      </div>
    </div>
  </div>

  <!-- Decorative bottom wave -->
  <div class="absolute bottom-0 left-0 right-0">
    <svg viewBox="0 0 1440 60" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="none" class="w-full h-12 fill-brand-surface">
      <path d="M0,40 C360,80 1080,0 1440,40 L1440,60 L0,60 Z" />
    </svg>
  </div>
</section>
