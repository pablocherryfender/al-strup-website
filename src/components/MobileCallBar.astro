---
import { siteConfig } from "@/lib/config";
---

<div class="fixed bottom-0 left-0 right-0 z-50 md:hidden" style="padding-bottom: env(safe-area-inset-bottom, 0px);">
  <a
    href={`tel:${siteConfig.phone}`}
    aria-label={`Zadzwoń do ${siteConfig.name} — bezpłatna wycena`}
    class="flex items-center justify-center gap-2 w-full bg-brand-primary text-white font-semibold py-4 text-base hover:bg-brand-primary-dark transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-white"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      class="h-5 w-5"
      fill="none"
      viewBox="0 0 24 24"
      stroke="currentColor"
      aria-hidden="true"
    >
      <path
        stroke-linecap="round"
        stroke-linejoin="round"
        stroke-width="2"
        d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 8V5z"
      ></path>
    </svg>
    Zadzwoń — bezpłatna wycena
  </a>
</div>
