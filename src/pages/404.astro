---
import Layout from "../layouts/Layout.astro";
---

<Layout title="404 — Strona nie istnieje | Allross" description="Nie znaleziono strony">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4">
    <p class="text-8xl font-bold text-brand-primary mb-4">404</p>
    <h1 class="text-2xl font-semibold text-brand-text mb-2">Strona nie istnieje</h1>
    <p class="text-brand-text/60 mb-8">Nie znaleźliśmy strony, której szukasz.</p>
    <a
      href="/"
      class="inline-block bg-brand-primary text-white px-6 py-3 rounded-lg font-medium hover:bg-brand-primary-dark transition-colors"
    >
      Wróć na stronę główną
    </a>
  </div>
</Layout>
