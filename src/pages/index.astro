---
import Layout from "../layouts/Layout.astro";
import Hero from "../components/Hero.astro";
import Services from "../components/Services.astro";
---

<Layout>
  <Hero />

  <Services />

  <section id="realizacje" class="min-h-screen flex items-center justify-center">
    <p class="text-brand-text/40 text-sm">Sekcja: Realizacje — wkrótce</p>
  </section>

  <section id="o-mnie" class="min-h-screen flex items-center justify-center">
    <p class="text-brand-text/40 text-sm">Sekcja: O mnie — wkrótce</p>
  </section>

  <section id="kontakt" class="min-h-screen flex items-center justify-center">
    <p class="text-brand-text/40 text-sm">Sekcja: Kontakt — wkrótce</p>
  </section>
</Layout>
